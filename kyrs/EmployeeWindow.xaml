<Window x:Class="kyrs.EmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дані співробітника" Height="450" Width="450" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Прізвище:" Grid.Row="0" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <TextBox Name="TxtLastName" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <TextBlock Text="Ім'я:" Grid.Row="1" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <TextBox Name="TxtFirstName" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <TextBlock Text="По батькові:" Grid.Row="2" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <TextBox Name="TxtMiddleName" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <TextBlock Text="Відділ:" Grid.Row="3" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <ComboBox Name="CmbDepartment" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5" Height="25" DisplayMemberPath="Name" FontSize="14"/>

        <TextBlock Text="Посада:" Grid.Row="4" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <ComboBox Name="CmbPosition" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5" Height="25" DisplayMemberPath="Name" FontSize="14"/>

        <TextBlock Text="Дата народження:" Grid.Row="5" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <DatePicker Name="DpAge" Grid.Row="5" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <TextBlock Text="Початок роботи:" Grid.Row="6" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <DatePicker Name="DpStartWork" Grid.Row="6" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <TextBlock Text="Зарплата:" Grid.Row="7" Grid.Column="0" Margin="0,5,10,5" VerticalAlignment="Center" FontSize="14"/>
        <TextBox Name="TxtMoney" Grid.Row="7" Grid.Column="1" Margin="0,5,0,5" Height="25" FontSize="14"/>

        <Grid Grid.Row="9" Grid.ColumnSpan="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Name="BtnClear" Content="Очистити форму" Background="#FFFF5555" Foreground="White" FontWeight="Bold" Height="35" Margin="0,0,5,0"/>
            <Button Name="BtnSave" Content="Зберегти" Background="#FF44BB44" Foreground="White" FontWeight="Bold" Height="35" Grid.Column="1" Margin="5,0,0,0"/>
        </Grid>
    </Grid>
</Window>