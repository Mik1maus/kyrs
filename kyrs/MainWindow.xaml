<Window x:Class="kyrs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kyrs"
        mc:Ignorable="d"
        Title="Управління персоналом" Height="500" Width="900" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Строка 0: Кнопки управления -->
            <RowDefinition Height="Auto"/>
            <!-- Строка 1: Таблица и детальная информация -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Левая колонка для таблицы -->
            <ColumnDefinition Width="1.5*"/>
            <!-- Правая колонка для детальной информации -->
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель с кнопками (как в примере преподавателя) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Name="BtnAddEmployee" Content="Додати співробітника" Margin="5" Height="30" Click="BtnAddEmployee_Click"/>
            <Button Name="BtnDeleteEmployee" Content="Видалити співробітника" Margin="5" Height="30" Grid.Column="1" Click="BtnDeleteEmployee_Click"/>
            <Button Name="BtnOpenStatistics" Content="Статистика" Margin="5" Height="30" Grid.Column="2" Click="BtnOpenStatistics_Click"/>
            <Button Name="BtnEditEmployee" Content="Редагувати інформацію" Margin="5" Height="30" Grid.Column="3" Click="BtnEditEmployee_Click"/>
        </Grid>

        <!-- Таблица для вывода сотрудников (слева) -->
        <!-- Я оставил тут только основные колонки, чтобы таблица не была перегружена -->
        <DataGrid Grid.Row="1" Grid.Column="0" Name="EmployeesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" Margin="5,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Прізвище" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Ім'я" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Відділ" Binding="{Binding Department.Name}" Width="*"/>
                <DataGridTextColumn Header="Зарплата" Binding="{Binding Money}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель детальной информации (справа) -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Прізвище:" Grid.Row="0" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblLastName" Content="Label" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Ім'я:" Grid.Row="1" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblFirstName" Content="Label" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="По батькові:" Grid.Row="2" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblMiddleName" Content="Label" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Відділ:" Grid.Row="3" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblDepartment" Content="Label" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Посада:" Grid.Row="4" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblPosition" Content="Label" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Дата народження:" Grid.Row="5" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblAge" Content="Label" Grid.Row="5" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Початок роботи:" Grid.Row="6" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblStartWork" Content="Label" Grid.Row="6" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>

                <TextBlock Text="Зарплата:" Grid.Row="7" Grid.Column="0" Margin="0,10,15,10" FontWeight="Bold"/>
                <Label Name="LblMoney" Content="Label" Grid.Row="7" Grid.Column="1" Margin="0,5,0,5" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

    </Grid>
</Window>