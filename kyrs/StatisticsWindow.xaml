<Window x:Class="kyrs.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="500" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Відділи за кількістю співробітників:" FontWeight="Bold" FontSize="14" Grid.Row="0" Margin="0,0,0,5"/>
        <DataGrid Name="DgDepartments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Відділ" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Кількість співробітників" Binding="{Binding Employees.Count}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="Топ 5 найстарших співробітників:" FontWeight="Bold" FontSize="14" Grid.Row="2" Margin="0,0,0,5"/>
        <DataGrid Name="DgOldest" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Прізвище" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Ім'я" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Дата народження" Binding="{Binding Age, StringFormat=dd.MM.yyyy}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Text="Середня зарплата по відділам:" FontWeight="Bold" FontSize="14" Grid.Row="4" Margin="0,0,0,5"/>
        <DataGrid Name="DgAverageSalary" Grid.Row="5" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Відділ" Binding="{Binding Key}" Width="*"/>
                <DataGridTextColumn Header="Середня зарплата" Binding="{Binding Value, StringFormat=C}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>